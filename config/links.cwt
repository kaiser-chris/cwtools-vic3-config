		type = scope
		prefix = num_ships_of_group:
		from_data = yes
		from_argument = yes
		data_source = scope[ship_group]
	}
	### Get the power projection value of the scoped formation, unit, or ship
	power_projection = {
		input_scopes = { new_combat_unit military_formation ship }
		output_scope = value
		type = value
	}
	### Compare a ship's armor
	armor = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Checks that a country has a certain fraction of a specific ship type
	country_ship_type_fraction = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = country_ship_type_fraction:
		from_data = yes
		from_argument = yes
		data_source = scope[ship_type]
	}
	### Checks that a formation has a certain fraction of a specific ship type
	formation_ship_type_fraction = {
		input_scopes = { military_formation }
		output_scope = value
		type = value
		prefix = formation_ship_type_fraction:
		from_data = yes
		from_argument = yes
		data_source = scope[ship_type]
	}
	### Compare a ship's current crew
	crew = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Compare a ship's current crew
	crew_percent = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Checks the scoped country's interest tier rank in a specific strategic region
	has_strategic_region_interest_tier = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = has_strategic_region_interest_tier:
		from_data = yes
		from_argument = yes
		data_source = scope[strategic_region]
	}
	### Compares the highest interest tier rank (scope country) among strategic regions where both countries have an interest.
	highest_overlapping_interest_tier = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = highest_overlapping_interest_tier:
		from_data = yes
		from_argument = yes
		data_source = scope[country]
	}
	### Compare a ship's current hit points
	hit_points = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Compare a ship's current hit points
	hit_points_percent = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Compares the loyalty in a given state, i.e. the fraction of Loyalists
	loyalists = {
		input_scopes = { state }
		output_scope = value
		type = value
	}
	### Checks the political strength share of a pop type, religion or culture in a country or state.
	political_strength_share_pop_type = {
		input_scopes = { country state }
		output_scope = value
		type = value
		prefix = political_strength_share:
		from_data = yes
		from_argument = yes
		data_source = scope[pop_type]
	}
	### Checks the political strength share of a pop type, religion or culture in a country or state.
	political_strength_share_religion = {
		input_scopes = { country state }
		output_scope = value
		type = value
		prefix = political_strength_share:
		from_data = yes
		from_argument = yes
		data_source = scope[religion]
	}
	### Checks the political strength share of a pop type, religion or culture in a country or state.
	political_strength_share_culture = {
		input_scopes = { country state }
		output_scope = value
		type = value
		prefix = political_strength_share:
		from_data = yes
		from_argument = yes
		data_source = scope[culture]
	}
	### Checks the wealth political strength share of a pop type, religion or culture in a country or state.
	wealth_share_pop_type = {
		input_scopes = { country state }
		output_scope = value
		type = value
		prefix = wealth_share:
		from_data = yes
		from_argument = yes
		data_source = scope[pop_type]
	}
	### Checks the wealth political strength share of a pop type, religion or culture in a country or state.
	wealth_share_religion = {
		input_scopes = { country state }
		output_scope = value
		type = value
		prefix = wealth_share:
		from_data = yes
		from_argument = yes
		data_source = scope[religion]
	}
	### Checks the wealth political strength share of a pop type, religion or culture in a country or state.
	wealth_share_culture = {
		input_scopes = { country state }
		output_scope = value
		type = value
		prefix = wealth_share:
		from_data = yes
		from_argument = yes
		data_source = scope[culture]
	}
	### Compare the potential income of the country (weekly income plus tax waste)
	potential_income = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Compare a ship's power projection
	power_projection_value = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Compares the character prominence
	prominence = {
		input_scopes = { character }
		output_scope = value
		type = value
	}
	### Compares the aggregated AI strategy region score for the specified strategic region in country scope
	region_score = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = region_score:
		from_data = yes
		from_argument = yes
		data_source = scope[strategic_region]
	}
	### Compares the priority of the character role
	role_priority = {
		input_scopes = { character_role }
		output_scope = value
		type = value
	}
	### Compare a ship's speed
	speed = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Compare the tax waste of the country
	tax_waste = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Compares the lifetime piracy income of a character
	lifetime_piracy_income = {
		input_scopes = { character }
		output_scope = value
		type = value
	}
	### Compares the military ship maintenance fulfillment ratio of a country
	military_ship_maintenance_fulfillment = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Compares the supply ship maintenance fulfillment ratio of a country
	supply_ship_maintenance_fulfillment = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Scope to the country's navy combat power
	naval_combat_power = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Scope to average damage dealt by this country in naval hostilities it initiated over the lookback period. Returns -1 if no hostilities found.
	naval_hostility_average_damage_dealt = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Scope to damage points inflicted by this country against another in active naval hostilities
	naval_hostility_damage = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = naval_hostility_damage:
		from_data = yes
		from_argument = yes
		data_source = scope[country]
	}
	### Scope to a country's naval vulnerability score based on trade reliance and coastal GDP share, capped at a define maximum
	naval_vulnerability = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Get the total marine capacity across all fleets of a country
	total_marine_capacity = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### AI valuation of a ship in £, equal to the current template-version construction cost times NAI::SHIP_TRANSFER_BASE_VALUE_PER_CONSTRUCTION_POINT
	ai_ship_value = {
		input_scopes = { ship }
		output_scope = value
		type = value
	}
	### Goods-weighted buy/sell ratio for the construction goods of the target ship modification, evaluated against the country-scope's market.
	ship_modification_market_demand_ratio = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = ship_modification_market_demand_ratio:
		from_argument = yes
		data_source = scope[ship_modification_type]
	}
	### Scope to the total average weekly base value of goods pilfered via piracy between two countries in a diplomatic relations scope
	total_pirated_trade_value = {
		input_scopes = { diplomatic_relations }
		output_scope = value
		type = value
	}
	### Scope to the ratio of diplomatic pact expenses to income for this country, clamped 0-1
	diplomatic_pact_expense_ratio = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Scope to the average weekly base value of goods pilfered from this country by a target country
	pirated_trade_value_by = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = pirated_trade_value_by:
		from_data = yes
		from_argument = yes
		data_source = scope[country]
	}
	### Scope to the trade importance of goods this country is trading through straits controlled by a target country. Accumulated value is multiplied by STRAIT_FULL_CONTROL_TRADE_IMPORTANCE_MULT for straits where the controller controls both sides
	strait_trade_importance_by = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = strait_trade_importance_by:
		from_data = yes
		from_argument = yes
		data_source = scope[country]
	}
	### Get the total crew needed by all ships of a country
	total_crew_needed = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Get the total marine capacity across all fleets of a country
	total_crew_needed = {
		input_scopes = { country }
		output_scope = value
		type = value
	}
	### Checks the size of a variable map
	### variable_map_size = { name = X value >= Y }
	### Where X is the name of the variable map
	### Where Y is a script value or number
	global_variable_map_size = {
		input_scopes = { any }
		output_scope = value
		type = value
		prefix = global_variable_map_size:
		from_argument = yes
		argument_separator = pipe
		data_source = value[global_variable_map]
	}
	### Checks the size of a variable map
	### variable_map_size = { name = X value >= Y }
	### Where X is the name of the variable map
	### Where Y is a script value or number
	local_variable_map_size = {
		input_scopes = { any }
		output_scope = value
		type = value
		prefix = local_variable_map_size:
		from_argument = yes
		argument_separator = pipe
		data_source = value[local_variable_map]
	}
	### Checks the size of a variable map
	### variable_map_size = { name = X value >= Y }
	### Where X is the name of the variable map
	### Where Y is a script value or number
	variable_map_size = {
		input_scopes = { any }
		output_scope = value
		type = value
		prefix = variable_map_size:
		from_argument = yes
		argument_separator = pipe
		data_source = value[variable_map]
	}
	### Reference a previous set variable via its name eg: "global_variable_map(average_relation_map|c:FRA)"
	global_variable_map = {
		input_scopes = { any }
		output_scope = any
		type = both
		prefix = global_variable_map:
		from_argument = yes
		argument_separator = pipe
		data_source = value[global_variable_map]
		data_source = scope_field
	}
	### Reference a previous set variable via its name eg: "global_variable_map(average_relation_map|c:FRA)"
	global_variable_map_value = {
		input_scopes = { any }
		output_scope = any
		type = both
		prefix = global_variable_map:
		from_argument = yes
		argument_separator = pipe
		data_source = value[global_variable_map]
		data_source = scalar
	}
	### Reference a previous set variable via its name eg: "local_variable_map(average_relation_map|c:FRA)"
	local_variable_map = {
		input_scopes = { any }
		output_scope = any
		type = both
		prefix = local_variable_map:
		from_argument = yes
		argument_separator = pipe
		data_source = value[local_variable_map]
		data_source = scope_field
	}
	### Reference a previous set variable via its name eg: "local_variable_map(average_relation_map|c:FRA)"
	local_variable_map_value = {
		input_scopes = { any }
		output_scope = any
		type = both
		prefix = local_variable_map:
		from_argument = yes
		argument_separator = pipe
		data_source = value[local_variable_map]
		data_source = scalar
	}
	### Reference a previous set variable via its name eg: "variable_map(average_relation_map|c:FRA)"
	variable_map = {
		input_scopes = { any }
		output_scope = any
		type = both
		prefix = variable_map:
		from_argument = yes
		argument_separator = pipe
		data_source = value[variable_map]
		data_source = scope_field
	}
	### Reference a previous set variable via its name eg: "variable_map(average_relation_map|c:FRA)"
	variable_map_value = {
		input_scopes = { any }
		output_scope = any
		type = both
		prefix = variable_map:
		from_argument = yes
		argument_separator = pipe
		data_source = value[variable_map]
		data_source = scalar
	}
	### Get the number of assigned supply ships for a military formation
	num_assigned_supply_ships = {
		input_scopes = { military_formation }
		output_scope = value
		type = value
	}
	### Compares the enactment success chance in scope country for given law but excludes values from enactment modifier
	enactment_chance_for_law_without_enactment_modifier = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = enactment_chance_for_law_without_enactment_modifier:
		from_data = yes
		from_argument = yes
		data_source = scope[country]
	}
	### Compares the number of days since a movement with this identity was last defeated in civil war. Returns max value if never defeated.
	days_since_movement_defeated = {
		input_scopes = { political_movement }
		output_scope = value
		type = value
	}
	### Compares the number of days since a movement of a given identity was last defeated in civil war. Returns max value if never defeated.
	days_since_movement_type_defeated = {
		input_scopes = { country }
		output_scope = value
		type = value
		prefix = days_since_movement_type_defeated:
		from_data = yes
		from_argument = yes
		data_source = scope[political_movement]
	}

	# script value & static value

    script_value = {
        input_scopes = { any }
        output_scope = value
        type = value
        from_data = yes
        data_source = <script_value>
    }
    static_value = {
        input_scopes = { any }
        output_scope = value
        type = value
        from_data = yes
        data_source = <static_value>
    }
}
